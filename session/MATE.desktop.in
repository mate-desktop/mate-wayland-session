[Desktop Entry]
Name=MATE (Wayland)
Comment=This session logs you into MATE using the Wayfire Wayland compositor
Exec=mate-wayland.sh
TryExec=mate-wayland.sh
Icon=mate
Type=Application
DesktopNames=MATE
X-GDM-SessionRegisters=true
